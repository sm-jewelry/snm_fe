# SNM Jewelry Ecommerce - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# API ENDPOINTS
# ============================================

# Main API Base URL (Cart, Wishlist, User APIs)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Category & Catalog API Base URL
NEXT_PUBLIC_CATEGORY_API_BASE_URL=http://localhost:4455

# Order Management API Base URL
NEXT_PUBLIC_ORDER_API_BASE_URL=http://localhost:3002

# ============================================
# AUTHENTICATION (ORY KRATOS + HYDRA)
# ============================================

# Ory Kratos Public URL
NEXT_KRATOS_PUBLIC_URL=http://localhost:4433

# Ory Hydra Login Frontend URL
NEXT_PUBLIC_LOGIN_FRONTEND_URL=http://localhost:3000/auth

# Ory Hydra Admin URL (Server-side only)
HYDRA_ADMIN_URL=http://localhost:4445

# OAuth2 Client ID
HYDRA_CLIENT_ID=your-client-id-here

# ============================================
# PAYMENT GATEWAY
# ============================================

# Razorpay API Key (India)
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxxxx

# TODO: Add Stripe keys for international payments
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx

# ============================================
# SITE CONFIGURATION
# ============================================

# Frontend Base URL
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Public Site URL (for SEO, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://stonemetaljewelry.com

# ============================================
# OPTIONAL: FUTURE ENHANCEMENTS
# ============================================

# Currency Exchange API (for multi-currency support)
# NEXT_PUBLIC_EXCHANGE_RATE_API_KEY=your-api-key

# Image CDN URL (for optimized image delivery)
# NEXT_PUBLIC_CDN_URL=https://cdn.stonemetaljewelry.com

# Analytics & Tracking
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Error Tracking (Sentry, etc.)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# NOTES
# ============================================
#
# 1. Never commit .env.local or .env files to version control
# 2. NEXT_PUBLIC_* variables are exposed to the browser
# 3. Variables without NEXT_PUBLIC_ are server-side only
# 4. For production, use environment-specific files or secrets management
#
